<?xml version="1.0" encoding="utf-8"?>
<!--
  PHASE 7.3 (Security Hardening) — Backup allow-list.

  Auto Backup (Android ≤ 11) and Cloud Backup (Android ≥ 12) both upload
  everything inside the app's internal storage to the user's Google Drive
  (or the configured backup provider) by default. For a file manager that
  holds private keys, encrypted vault metadata, and OCR output, this is
  unacceptable: the SFTP host key and the vault database would silently
  leave the device.

  This allow-list excludes the sensitive paths while preserving Auto Backup
  for user-visible data we DO want to keep across reinstalls (e.g. tags
  applied to files, smart folders, user preferences). The vault's encrypted
  payload lives under files/vault/ which is also excluded — without the
  key, the file is opaque anyway, but excluding it keeps the wire payload
  smaller and removes ambiguity.
-->
<full-backup-content>
    <!-- Strict allow-list. No file-domain content is backed up: rootfs,
         terminal state, keys, vault payloads, OCR and temporary downloads
         therefore fail closed when new paths are added. -->
    <include domain="database" path="titan_sovereign.db" />
    <include domain="sharedpref" path="elysium_palette_prefs.xml" />
    <include domain="sharedpref" path="elysium_music_prefs.xml" />
    <include domain="sharedpref" path="elysium_gallery_prefs.xml" />
    <include domain="sharedpref" path="elysium_trash_config.xml" />
</full-backup-content>
